{
  "name": "swiishh",
  "version": "1.0.0",
  "description": "Hand-gesture basketball in the browser — MediaPipe hand tracking + a custom rigid-body ball sim. TypeScript throughout, zero runtime dependencies.",
  "homepage": "https://swiishh.sindbug.com/",
  "repository": { "type": "git", "url": "git+https://github.com/rayhantr/swiishh.git" },
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.build.json && node --disable-warning=ExperimentalWarning tools/build.ts",
    "watch": "tsc -p tsconfig.build.json --watch",
    "typecheck": "tsc",
    "assets": "node --disable-warning=ExperimentalWarning tools/make-assets.ts",
    "start": "yarn build && node --disable-warning=ExperimentalWarning tools/serve.ts",
    "test": "yarn typecheck && node --disable-warning=ExperimentalWarning tests/simulate.ts"
  },
  "keywords": [
    "basketball",
    "mediapipe",
    "hand-tracking",
    "gesture",
    "game",
    "canvas",
    "physics",
    "typescript"
  ],
  "author": "Rayhan",
  "license": "MIT",
  "packageManager": "yarn@1.22.22",
  "engines": {
    "node": "22.x",
    "yarn": "1.x"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "typescript": "^6.0.3"
  }
}
