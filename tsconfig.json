{
  // Type-checking config for the whole repo (src + tests + tools).
  // `yarn typecheck` uses this; the browser build uses tsconfig.build.json.
  //
  // Imports use explicit `.ts` extensions so Node ≥ 22.18 can run tests and
  // tools directly via native type stripping — no build step outside the
  // browser bundle. `erasableSyntaxOnly` guarantees we never use TS syntax
  // (enums, namespaces, parameter properties) that type stripping can't erase.
  "compilerOptions": {
    "target": "ES2022",
    "module": "esnext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["node"],

    "strict": true,
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "rewriteRelativeImportExtensions": true,
    "erasableSyntaxOnly": true,
    "verbatimModuleSyntax": true,
    "isolatedModules": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["src", "tests", "tools"]
}
